  "sentences": [
    {
      "id": "ch29-01",
      "text": "Au secours !",
      "imagePrompt": "Medium shot, eye-level, inside a steampunk cable car suspended over an industrial chasm. Avril faces the viewer gripping the railing, Darwin clinging to her shoulder. A glowing brass altimeter on the dashboard is the focal point. Hazy daylight through steam, tense and urgent mood.",
      "readings": [],
      "type": "teaching",
      "group": "cable_car_danger",
      "speaker": "Avril"
    },
    {
      "id": "ch29-02",
      "text": "Avril regarde l'altimètre.",
      "imagePrompt": "",
      "readings": [],
      "type": "teaching",
      "group": "cable_car_danger",
      "speaker": "Avril"
    },
    {
      "id": "ch29-03",
      "text": "On va agir maintenant parce que Darwin va mal.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "cable_car_danger",
      "speaker": "Paul"
    },
    {
      "id": "ch29-04",
      "text": "Darwin ne va pas bien.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "cable_car_danger",
      "speaker": "Darwin"
    },
    {
      "id": "ch29-05",
      "text": "La cheminée est là.",
      "imagePrompt": "Medium shot, eye-level, of Avril facing the viewer inside the cable car, pointing toward a massive brass chimney venting white steam against the daylit steampunk cityscape. The chimney is the focal point. Avril's eyes narrow with a forming plan. Bright hazy daylight, determined and strategic mood.",
      "readings": [],
      "type": "teaching",
      "group": "chimney_escape",
      "speaker": "Avril"
    },
    {
      "id": "ch29-06",
      "text": "Avril va sauver Darwin.",
      "imagePrompt": "",
      "readings": [],
      "type": "teaching",
      "group": "chimney_escape",
      "speaker": "Avril"
    },
    {
      "id": "ch29-07",
      "text": "Au secours, dit Avril.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "chimney_escape",
      "speaker": "Avril"
    },
    {
      "id": "ch29-08",
      "text": "La cheminée est grande comme un arbre.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "chimney_escape",
      "speaker": "Paul"
    },
    {
      "id": "ch29-09",
      "text": "Elle va le sauver.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "chimney_escape",
      "speaker": "Paul"
    },
    {
      "id": "ch29-10",
      "text": "Ça va très mal.",
      "imagePrompt": "Medium shot, eye-level, of Avril facing the viewer, gripping a heavy brass lever inside the cable car cockpit, about to pull it a third time. The lever is the focal point. The altimeter needle swings wildly on the dashboard. Daylight through the windshield, desperate and strained mood.",
      "readings": [],
      "type": "teaching",
      "group": "three_tries",
      "speaker": "Avril"
    },
    {
      "id": "ch29-11",
      "text": "Avril essaye trois fois.",
      "imagePrompt": "",
      "readings": [],
      "type": "teaching",
      "group": "three_tries",
      "speaker": "Avril"
    },
    {
      "id": "ch29-12",
      "text": "L'altimètre bouge d'un coup.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "three_tries",
      "speaker": "Paul"
    },
    {
      "id": "ch29-13",
      "text": "Trois fois, elle essaye.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "three_tries",
      "speaker": "Paul"
    },
    {
      "id": "ch29-14",
      "text": "Avril est très forte.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "three_tries",
      "speaker": "Avril"
    },
    {
      "id": "ch29-15",
      "text": "C'est un coup de magie.",
      "imagePrompt": "Medium shot, eye-level, of Avril facing the viewer inside the cable car, her raised fist about to strike a brass control panel, the panel as focal point. Darwin braces beside her. Daylight and steam fill the cockpit, mood of fierce concentration in the moment before the blow.",
      "readings": [],
      "type": "teaching",
      "group": "the_blow",
      "speaker": "Avril"
    },
    {
      "id": "ch29-16",
      "text": "Parce que le feu est là.",
      "imagePrompt": "",
      "readings": [],
      "type": "teaching",
      "group": "the_blow",
      "speaker": "Paul"
    },
    {
      "id": "ch29-17",
      "text": "Le coup est bon.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "the_blow",
      "speaker": "Paul"
    },
    {
      "id": "ch29-18",
      "text": "Le secours arrive.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "the_blow",
      "speaker": "Narrateur"
    },
    {
      "id": "ch29-19",
      "text": "C'est bon parce que Avril agit.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "the_blow",
      "speaker": "Paul"
    },
    {
      "id": "ch29-20",
      "text": "Le feu arrive lorsqu'Avril agit !",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "the_blow",
      "speaker": "Paul"
    },
    {
      "id": "ch29-21",
      "text": "Avril va sauver tout le monde.",
