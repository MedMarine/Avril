      "type": "flow",
      "group": "reunion",
      "speaker": "Narrateur"
    },
    {
      "id": "ch46-10",
      "text": "La retrouvaille approche lorsqu'on cherche.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "reunion",
      "speaker": "Avril"
    },
    {
      "id": "ch46-11",
      "text": "C'est la disposition du labo.",
      "imagePrompt": "In a steampunk Paris alley lit by a nearby streetlamp, Avril and Julius face the viewer examining a stolen blueprint of the Ligue headquarters spread on a wooden crate, the detailed layout clearly visible on the paper. Medium shot, eye-level. Warm amber streetlamp light on the blueprint, secretive and strategic mood.",
      "readings": [],
      "type": "teaching",
      "group": "layout",
      "speaker": "Avril"
    },
    {
