  "sentences": [
    {
      "id": "ch46-01",
      "text": "Il y a un indice.",
      "imagePrompt": "On a smoky steampunk Paris street, Avril faces the viewer pointing at a hidden clue scratched into a brass lamppost, the cryptic markings clearly visible on the metal surface, Darwin sniffing at the base. Medium shot, eye-level. Amber gaslight from the lamppost above, curious and investigative mood.",
      "readings": [],
      "type": "teaching",
      "group": "clue",
      "speaker": "Avril"
    },
    {
      "id": "ch46-02",
      "text": "Avril décide de chercher.",
      "imagePrompt": "",
      "readings": [],
      "type": "teaching",
      "group": "clue",
      "speaker": "Avril"
    },
    {
      "id": "ch46-03",
      "text": "L'indice qu'Avril a trouvé est bon.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "clue",
      "speaker": "Avril"
    },
    {
      "id": "ch46-04",
      "text": "Avril a décidé car il faut chercher.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "clue",
      "speaker": "Avril"
    },
    {
      "id": "ch46-05",
      "text": "Il faut chercher parce que la retrouvaille approche.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "clue",
      "speaker": "Avril"
    },
    {
      "id": "ch46-06",
      "text": "La retrouvaille est ici.",
      "imagePrompt": "In a steampunk Paris back street, Avril faces the viewer holding up a crucial handwritten letter she has just discovered tucked inside a brass mailbox, hope and recognition dawning on her face. Medium shot, eye-level. Warm streetlamp gaslight on the aged paper, hopeful and emotional mood.",
      "readings": [],
      "type": "teaching",
      "group": "reunion",
      "speaker": "Avril"
    },
    {
      "id": "ch46-07",
      "text": "On approche du labo.",
      "imagePrompt": "",
      "readings": [],
      "type": "teaching",
      "group": "reunion",
      "speaker": "Avril"
    },
    {
      "id": "ch46-08",
