  "sentences": [
    {
      "id": "ch21-01",
      "text": "Il n'y avait pas d'électricité.",
      "imagePrompt": "Wide shot, eye-level, of a steampunk Paris street with no electric lights visible anywhere. Residents carry oil lamps past soot-covered buildings while coal-smoke drifts from every chimney. Muted sepia tones convey a bleak, energy-starved world at dusk.",
      "readings": [],
      "type": "teaching",
      "group": "no_power",
      "speaker": "Avril"
    },
    {
      "id": "ch21-02",
      "text": "On cherchait du bois.",
      "imagePrompt": "",
      "readings": [],
      "type": "teaching",
      "group": "no_power",
      "speaker": "Avril"
    },
    {
      "id": "ch21-03",
      "text": "Le monde vivait sans électricité.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "no_power",
      "speaker": "Avril"
    },
    {
      "id": "ch21-04",
      "text": "On utilisait le bois.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "no_power",
      "speaker": "Avril"
    },
    {
      "id": "ch21-05",
      "text": "Le bois donnait de l'énergie.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "no_power",
      "speaker": "Avril"
    },
    {
      "id": "ch21-06",
      "text": "Les policiers cherchaient les savants.",
      "imagePrompt": "Medium shot, eye-level, of two steampunk policemen facing the viewer on a foggy cobblestone street, one holding a lantern, the other nailing a wanted poster for a missing scientist onto a soot-covered wall. Cold lantern glow cuts through grey fog, tense and oppressive.",
      "readings": [],
      "type": "teaching",
      "group": "hunt",
      "speaker": "Avril"
    },
    {
      "id": "ch21-07",
      "text": "La maladie était là.",
