      "readings": [],
      "type": "flow",
      "group": "hunt",
      "speaker": "Avril"
    },
    {
      "id": "ch21-09",
      "text": "Les policiers arrivaient la nuit.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "hunt",
      "speaker": "Avril"
    },
    {
      "id": "ch21-10",
      "text": "La maladie détruisait la vie.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "hunt",
      "speaker": "Avril"
    },
    {
      "id": "ch21-11",
      "text": "On survivait avec le charbon.",
      "imagePrompt": "Medium shot, eye-level, of a family huddled around a glowing coal stove in a cramped steampunk apartment. A woman facing the viewer holds wood scraps, soot on her cheeks. The coal stove is the focal point, casting warm orange light in an otherwise grey, desperate room.",
