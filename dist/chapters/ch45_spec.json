  "sentences": [
    {
      "id": "ch45-01",
      "text": "C'est un collectionneur.",
      "imagePrompt": "In a vast steampunk hall, a sinister collector in a long coat faces the viewer standing before rows of glass pods containing kidnapped scientists, each pod bearing a brass label and catalogue number. Wide shot, eye-level. Cold gaslight from ceiling fixtures, ominous and clinical mood.",
      "readings": [],
      "type": "teaching",
      "group": "collector",
      "speaker": "Narrateur"
    },
    {
      "id": "ch45-02",
      "text": "Il possède les savants.",
      "imagePrompt": "",
      "readings": [],
      "type": "teaching",
      "group": "collector",
      "speaker": "Avril"
    },
    {
      "id": "ch45-03",
      "text": "Le collectionneur possède tout parce qu'il a les savants.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "collector",
      "speaker": "Avril"
    },
    {
      "id": "ch45-04",
      "text": "On possède tout si on a les savants.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "collector",
      "speaker": "Avril"
    },
    {
      "id": "ch45-05",
      "text": "C'est la Ligue qui possède les savants.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "collector",
      "speaker": "Avril"
    },
    {
      "id": "ch45-06",
      "text": "C'est une partie du rêve.",
      "imagePrompt": "In the collector's hall, Avril faces the viewer gazing at a large painted mural on the wall depicting a dream of green forests, electric lights, and flying machines, the vibrant colors contrasting with the grey steampunk room around her. Medium shot, eye-level. Soft gaslight illuminating the vivid mural, wistful and longing mood.",
      "readings": [],
      "type": "teaching",
      "group": "dream",
      "speaker": "Avril"
    },
    {
      "id": "ch45-07",
      "text": "On examine le monde.",
      "imagePrompt": "",
      "readings": [],
      "type": "teaching",
      "group": "dream",
      "speaker": "Avril"
    },
    {
      "id": "ch45-08",
      "text": "Le rêve que le collectionneur examine est grand.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "dream",
      "speaker": "Avril"
    },
    {
      "id": "ch45-09",
      "text": "On examine tout.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "dream",
      "speaker": "Narrateur"
    },
    {
      "id": "ch45-10",
      "text": "La partie est grande.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "dream",
      "speaker": "Avril"
    },
    {
      "id": "ch45-11",
      "text": "La garde est ici.",
      "imagePrompt": "In a gaslit corridor of the collector's fortress, two armored steampunk guards face the viewer standing at attention with brass rifles, mechanical surveillance devices mounted on the iron walls behind them. Medium shot, eye-level. Harsh gaslight from wall-mounted fixtures glinting off their armor, intimidating and watchful mood.",
      "readings": [],
      "type": "teaching",
      "group": "guards",
      "speaker": "Avril"
    },
    {
      "id": "ch45-12",
      "text": "Il faut activer le sérum.",
      "imagePrompt": "",
      "readings": [],
      "type": "teaching",
      "group": "guards",
      "speaker": "Avril"
    },
    {
      "id": "ch45-13",
      "text": "La garde regarde tout.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "guards",
      "speaker": "Avril"
    },
    {
      "id": "ch45-14",
      "text": "On a activé le sérum.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "guards",
      "speaker": "Avril"
    },
    {
      "id": "ch45-15",
      "text": "La garde ne bouge pas.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "guards",
      "speaker": "Avril"
    },
    {
      "id": "ch45-16",
      "text": "Le rêve est un collectionneur.",
      "imagePrompt": "In the collector's private gallery, shelves of stolen inventions and glowing seized serum vials line the walls, each item displayed beneath a brass plaque naming the captured scientist who created it. Wide shot, eye-level. Amber gaslight from ornate fixtures on polished brass, covetous and unsettling mood.",
      "readings": [],
      "type": "teaching",
      "group": "possession",
      "speaker": "Avril"
    },
    {
      "id": "ch45-17",
      "text": "Ça suffit.",
      "imagePrompt": "",
      "readings": [],
      "type": "teaching",
      "group": "possession",
      "speaker": "Narrateur"
    },
    {
      "id": "ch45-18",
      "text": "Ça ne suffit pas.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "possession",
      "speaker": "Avril"
    },
    {
      "id": "ch45-19",
      "text": "On possède le rêve.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "possession",
      "speaker": "Avril"
    },
    {
      "id": "ch45-20",
      "text": "Ça suffit ici.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "possession",
      "speaker": "Narrateur"
    },
    {
      "id": "ch45-21",
      "text": "Avril examine la partie.",
      "imagePrompt": "In a gaslit fortress corridor, Avril faces the viewer crouching beside a ventilation grate studying the layout beyond it, Darwin scouting nearby under the warm glow of a wall-mounted gas lamp. Medium shot, eye-level. Flickering gas lamp light on stone walls, stealthy and calculating mood.",
      "readings": [],
      "type": "teaching",
      "group": "escape",
      "speaker": "Avril"
    },
    {
      "id": "ch45-22",
      "text": "On active la garde.",
      "imagePrompt": "",
      "readings": [],
      "type": "teaching",
      "group": "escape",
      "speaker": "Avril"
    },
    {
