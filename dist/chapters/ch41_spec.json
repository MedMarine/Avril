  "sentences": [
    {
      "id": "ch41-01",
      "text": "La colère est là.",
      "imagePrompt": "On a polluted steampunk Paris street, Avril faces the viewer with clenched fists and a furious expression, her anger visible in her flushed face and tight jaw. Medium shot, eye-level. Hazy grey daylight filters through coal smoke, tense and oppressive mood.",
      "readings": [],
      "type": "teaching",
      "group": "anger",
      "speaker": "Avril"
    },
    {
      "id": "ch41-02",
      "text": "C'est la langue d'Avril.",
      "imagePrompt": "",
      "readings": [],
      "type": "teaching",
      "group": "anger",
      "speaker": "Avril"
    },
    {
      "id": "ch41-03",
      "text": "La colère est grande parce que le monde va mal.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "anger",
      "speaker": "Avril"
    },
    {
      "id": "ch41-04",
      "text": "La langue dit tout car Avril est en colère.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "anger",
      "speaker": "Avril"
    },
    {
      "id": "ch41-05",
      "text": "Il faut agir car la colère seule ne change rien.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "anger",
      "speaker": "Avril"
    },
    {
      "id": "ch41-06",
      "text": "Ça ne fonctionne pas.",
      "imagePrompt": "On a grimy steampunk Paris sidewalk, Avril stands facing the viewer beside a sputtering, broken steam-powered machine with gears jammed and steam leaking from cracked pipes. Medium shot, eye-level. Overcast daylight through smog, frustrated and bleak mood.",
      "readings": [],
      "type": "teaching",
      "group": "broken_world",
      "speaker": "Avril"
    },
    {
      "id": "ch41-07",
      "text": "On surveille Avril.",
      "imagePrompt": "",
      "readings": [],
      "type": "teaching",
      "group": "broken_world",
      "speaker": "Avril"
    },
    {
      "id": "ch41-08",
      "text": "Rien ne fonctionne ici.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "broken_world",
      "speaker": "Avril"
    },
    {
      "id": "ch41-09",
      "text": "On la surveille.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "broken_world",
      "speaker": "Narrateur"
    },
    {
      "id": "ch41-10",
      "text": "Le monde reste dans la nuit parce que rien ne fonctionne.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "broken_world",
      "speaker": "Avril"
    },
    {
      "id": "ch41-11",
      "text": "C'est le siècle de la saleté.",
      "imagePrompt": "From a barren hilltop, Avril faces the viewer overlooking a vast deforested steampunk landscape stretching to the horizon, coal smoke rising from distant factories under a sepia sky. Wide shot, eye-level. Dim, hazy daylight through pollution, weary and sorrowful mood.",
      "readings": [],
      "type": "teaching",
      "group": "century",
      "speaker": "Avril"
    },
    {
      "id": "ch41-12",
      "text": "On a volé les savants.",
      "imagePrompt": "",
      "readings": [],
      "type": "teaching",
      "group": "century",
      "speaker": "Avril"
    },
    {
      "id": "ch41-13",
      "text": "Le siècle est long.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "century",
      "speaker": "Avril"
    },
    {
      "id": "ch41-14",
      "text": "On vole le monde.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "century",
      "speaker": "Avril"
    },
    {
      "id": "ch41-15",
      "text": "Il faut surveiller la bande qui vole les savants.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "century",
      "speaker": "Avril"
    },
    {
      "id": "ch41-16",
      "text": "La lecture est ici.",
      "imagePrompt": "Under a gaslit steampunk streetlamp, Avril faces the viewer holding her father's research notes open before her, handwritten formulas and diagrams visible on the pages. Medium shot, eye-level. Warm amber gaslight against the dark street, quiet and determined mood.",
      "readings": [],
      "type": "teaching",
      "group": "reading",
      "speaker": "Avril"
    },
    {
      "id": "ch41-17",
      "text": "Ça fonctionne, dit Avril.",
      "imagePrompt": "",
      "readings": [],
      "type": "teaching",
      "group": "reading",
      "speaker": "Avril"
    },
    {
      "id": "ch41-18",
      "text": "La lecture du siècle.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "reading",
      "speaker": "Avril"
    },
    {
      "id": "ch41-19",
      "text": "La colère passe.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "reading",
      "speaker": "Narrateur"
    },
    {
      "id": "ch41-20",
      "text": "Avril a volé la lecture.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "reading",
      "speaker": "Avril"
    },
    {
      "id": "ch41-21",
      "text": "Avril embrasse Darwin.",
      "imagePrompt": "On a steampunk Paris rooftop, Avril faces the viewer embracing Darwin the cat against her chest, her arms wrapped tenderly around him, the smoky city skyline behind them. Medium shot, eye-level. Soft diffused daylight through clouds, warm and gentle mood.",
      "readings": [],
      "type": "teaching",
      "group": "embrace",
      "speaker": "Avril"
    },
    {
      "id": "ch41-22",
      "text": "La langue de Darwin est là.",
      "imagePrompt": "",
      "readings": [],
      "type": "teaching",
      "group": "embrace",
      "speaker": "Avril"
