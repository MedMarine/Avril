      "group": "thief",
      "speaker": "Avril"
    },
    {
      "id": "ch40-06",
      "text": "Le voleur est de l'orphelinat.",
      "imagePrompt": "Medium shot, eye-level, of Julius facing the viewer in the underground hideout, eyes downcast as he speaks of his past. Behind him on the stone wall, a faded charity poster shows a grim iron-gated orphanage building with soot-stained walls. Oil lamps flicker warm light across his troubled face, mood vulnerable and melancholy.",
      "readings": [],
      "type": "teaching",
      "group": "orphanage",
      "speaker": "Julius"
    },
    {
      "id": "ch40-07",
      "text": "Avril a envie de le choper.",
