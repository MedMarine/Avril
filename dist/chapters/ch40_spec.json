      "readings": [],
      "type": "flow",
      "group": "orphanage",
      "speaker": "Julius"
    },
    {
      "id": "ch40-10",
      "text": "Avril va le choper !",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "orphanage",
      "speaker": "Avril"
    },
    {
      "id": "ch40-11",
      "text": "Il faut lâcher le chat !",
