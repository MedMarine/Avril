  "sentences": [
    {
      "id": "ch40-01",
      "text": "C'est un voleur !",
      "imagePrompt": "Medium shot, eye-level, of Julius sitting across from Avril in the underground hideout, his worn leather satchel open on the table revealing a brass grappling hook. Pops watches from a nearby chair. Oil lamps cast warm amber light on Julius's guarded face, mood confessional and tense.",
      "readings": [],
      "type": "teaching",
      "group": "thief",
      "speaker": "Julius"
    },
    {
      "id": "ch40-02",
      "text": "Il a un grappin.",
