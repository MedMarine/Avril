  "sentences": [
    {
      "id": "ch22-01",
      "text": "L'enfant qui joue a gagné.",
      "imagePrompt": "Wide shot, eye-level, of a bustling steampunk fairground with a chemistry show on a wooden stage. A young performer faces the viewer, arms raised in triumph after winning applause. Colourful flames rise from glass beakers on the stage. Warm gaslight glow over the excited crowd, mood festive and lively.",
      "readings": [],
      "type": "teaching",
      "group": "show",
      "speaker": "Avril"
    },
    {
      "id": "ch22-02",
      "text": "C'est un plaisir de regarder.",
      "imagePrompt": "",
      "readings": [],
      "type": "teaching",
      "group": "show",
      "speaker": "Avril"
    },
    {
      "id": "ch22-03",
      "text": "L'homme qui gagne est fort.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "show",
      "speaker": "Avril"
    },
    {
      "id": "ch22-04",
      "text": "Avril a gagné encore.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "show",
      "speaker": "Avril"
    },
    {
      "id": "ch22-05",
      "text": "Le plaisir est grand parce qu'Avril a gagné.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "show",
      "speaker": "Avril"
    },
    {
      "id": "ch22-06",
      "text": "On fabrique avec le charbon.",
      "imagePrompt": "Medium shot, eye-level, of a steampunk chemistry booth at the fair. A man facing the viewer fabricates a brass device from gears and glass tubes. Numbered vials labelled one through five line a wooden counter, the focal point. Warm gaslight and fairground lanterns illuminate the scene, mood industrious and curious.",
      "readings": [],
      "type": "teaching",
      "group": "craft",
      "speaker": "Avril"
    },
    {
      "id": "ch22-07",
      "text": "C'est le numéro deux.",
      "imagePrompt": "",
      "readings": [],
      "type": "teaching",
      "group": "craft",
      "speaker": "Avril"
    },
    {
      "id": "ch22-08",
      "text": "Avril fabrique l'énergie.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "craft",
      "speaker": "Avril"
    },
    {
      "id": "ch22-09",
      "text": "Le numéro un est parti.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "craft",
      "speaker": "Avril"
    },
    {
      "id": "ch22-10",
      "text": "On fabrique si on a le temps.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "craft",
      "speaker": "Avril"
    },
    {
      "id": "ch22-11",
      "text": "Julius attrape le chat !",
