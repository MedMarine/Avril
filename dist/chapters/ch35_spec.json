      "readings": [],
      "type": "flow",
      "group": "two_weeks",
      "speaker": "Pops"
    },
    {
      "id": "ch35-15",
      "text": "On se lève encore.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "two_weeks",
      "speaker": "Pops"
    },
    {
      "id": "ch35-16",
      "text": "Tout le monde est vivant.",
