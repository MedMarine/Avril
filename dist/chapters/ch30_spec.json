  "sentences": [
    {
      "id": "ch30-01",
      "text": "C'est un grand jour.",
      "imagePrompt": "Wide shot, eye-level, of Napoleon III arriving in a grand steampunk laboratory in 1870, wearing an ornate military uniform with medals, facing the viewer. A stone inscription reading 1870 is carved above the laboratory entrance. The massive brass reactor stands behind the old scientist, the reactor as focal point. Bright gaslight chandeliers, imposing and ceremonial mood.",
      "readings": [],
      "type": "teaching",
      "group": "napoleon_arrives",
      "speaker": "Gustave"
    },
    {
      "id": "ch30-02",
      "text": "Le savant regarde le réacteur.",
      "imagePrompt": "",
      "readings": [],
      "type": "teaching",
      "group": "napoleon_arrives",
      "speaker": "Gustave"
    },
    {
      "id": "ch30-03",
      "text": "C'est le jour où l'Empereur arrive.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "napoleon_arrives",
      "speaker": "Gustave"
    },
    {
      "id": "ch30-04",
      "text": "Le réacteur que le savant regarde est grand.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "napoleon_arrives",
      "speaker": "Gustave"
    },
    {
      "id": "ch30-05",
      "text": "Le monsieur arrive.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "napoleon_arrives",
      "speaker": "Narrateur"
    },
    {
      "id": "ch30-06",
      "text": "Vous avez peu de temps, dit-il.",
      "imagePrompt": "Medium shot, eye-level, of Napoleon III facing the viewer, speaking sternly with an imperious gesture toward the old scientist in the grand laboratory. Brass instruments gleam on the walls, guards at attention behind him. Bright gaslight, authoritative and pressured mood.",
      "readings": [],
      "type": "teaching",
      "group": "emperor_speaks",
      "speaker": "Gustave"
    },
    {
      "id": "ch30-07",
      "text": "L'Empereur dit une chose.",
      "imagePrompt": "",
      "readings": [],
      "type": "teaching",
      "group": "emperor_speaks",
      "speaker": "Gustave"
    },
    {
      "id": "ch30-08",
      "text": "Il y a peu de temps.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "emperor_speaks",
      "speaker": "Gustave"
    },
    {
      "id": "ch30-09",
      "text": "Le jour passe.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "emperor_speaks",
      "speaker": "Narrateur"
    },
    {
      "id": "ch30-10",
      "text": "La chose que dit l'Empereur est sûre.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "emperor_speaks",
      "speaker": "Gustave"
    },
    {
      "id": "ch30-11",
      "text": "Vous allez continuer.",
      "imagePrompt": "Medium shot, eye-level, of Napoleon III facing the viewer, pointing commandingly at the old scientist who holds blueprints beside the brass reactor. Steam drifts through the laboratory. The blueprints are the focal point. Bright gaslight and steam haze, commanding and unyielding mood.",
      "readings": [],
      "type": "teaching",
      "group": "orders",
      "speaker": "Narrateur"
    },
    {
      "id": "ch30-12",
      "text": "On ne va pas ignorer cela.",
      "imagePrompt": "",
      "readings": [],
      "type": "teaching",
      "group": "orders",
      "speaker": "Gustave"
    },
    {
