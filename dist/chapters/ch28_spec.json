  "sentences": [
    {
      "id": "ch28-01",
      "text": "Avril pense à son papa.",
      "imagePrompt": "Medium shot, eye-level, of Avril facing the viewer at a heavy wooden table in a warm steampunk kitchen, chin resting on her hand in thought. Pops sits across from her. The glowing coal stove provides warm amber light, pensive and contemplative mood.",
