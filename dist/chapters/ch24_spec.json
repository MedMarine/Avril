  "sentences": [
    {
      "id": "ch24-01",
      "text": "Avril va à la fête.",
      "imagePrompt": "Wide shot, eye-level, of Avril arriving at a steampunk summer fairground covered in soot. A steam-powered carousel spins behind crowds in soot-stained Victorian clothes. Fine grey soot drifts through the air, the focal point. Overcast daylight, lively but gritty mood.",
      "readings": [],
      "type": "teaching",
      "group": "fair_opening",
      "speaker": "Avril"
    },
    {
      "id": "ch24-02",
      "text": "Il y a de la suie.",
      "imagePrompt": "",
      "readings": [],
      "type": "teaching",
      "group": "fair_opening",
      "speaker": "Avril"
    },
    {
      "id": "ch24-03",
      "text": "La fête est grande lorsqu'Avril arrive.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "fair_opening",
      "speaker": "Avril"
    },
    {
      "id": "ch24-04",
      "text": "Elle y va avec Darwin.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "fair_opening",
      "speaker": "Avril"
    },
    {
      "id": "ch24-05",
      "text": "La suie tombe ici.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "fair_opening",
      "speaker": "Avril"
    },
    {
      "id": "ch24-06",
      "text": "Avril aime la fête, mais la suie tombe.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "fair_opening",
      "speaker": "Avril"
    },
    {
      "id": "ch24-07",
      "text": "C'est un échange.",
      "imagePrompt": "Medium shot, eye-level, of a steampunk market stall at the fair where a mechanic facing the viewer repairs a brass steam device. Gears and tools spread across the counter as two traders exchange goods beside him. Warm lantern light over the busy stall, industrious mood.",
      "readings": [],
      "type": "teaching",
      "group": "exchange",
      "speaker": "Narrateur"
    },
    {
      "id": "ch24-08",
      "text": "On répare la porte.",
      "imagePrompt": "",
      "readings": [],
      "type": "teaching",
      "group": "exchange",
      "speaker": "Avril"
    },
    {
      "id": "ch24-09",
      "text": "L'échange est bon.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "exchange",
      "speaker": "Narrateur"
    },
    {
      "id": "ch24-10",
      "text": "Avril en a trouvé un.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "exchange",
      "speaker": "Avril"
    },
    {
      "id": "ch24-11",
      "text": "On répare l'arme.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "exchange",
      "speaker": "Narrateur"
    },
    {
      "id": "ch24-12",
      "text": "On en répare deux.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "exchange",
      "speaker": "Avril"
    },
    {
      "id": "ch24-13",
      "text": "Avril entend un tir.",
      "imagePrompt": "Medium shot, eye-level, of a steampunk target gallery booth at the fair with tin targets on springs. Avril faces the viewer, frozen mid-step, startled by a loud bang from the booth. Soot particles float in the lantern-lit air, tense and surprised mood.",
      "readings": [],
      "type": "teaching",
      "group": "shooting",
      "speaker": "Avril"
    },
    {
      "id": "ch24-14",
      "text": "Darwin ne bouge pas.",
      "imagePrompt": "",
      "readings": [],
      "type": "teaching",
      "group": "shooting",
      "speaker": "Darwin"
    },
    {
      "id": "ch24-15",
      "text": "Le tir est loin, mais Avril l'entend.",
      "imagePrompt": "",
      "readings": [],
      "type": "flow",
      "group": "shooting",
      "speaker": "Avril"
    },
    {
      "id": "ch24-16",
